// Nextflow Configuration for Fairway
// Customize profiles and execution settings here

params {
    // Config file path
    config = "config/fairway.yaml"

    // Output directory
    outdir = "results"

    // Container image for Apptainer/Docker execution
    container_image = "docker://ghcr.io/dissc-yale/fairway:latest"

    // Orchestration parameters (can be overridden via CLI)
    table = null           // Table to process (required for batch mode)
    n_batches = null       // Override batch count (calculated dynamically if null)
    spark_master = null    // Spark master URL (passed by driver.sh)
    work_dir = ".fairway/work"  // Work directory for batch outputs
}

profiles {
    // Local execution (default)
    standard {
        process.executor = 'local'
    }

    // Slurm cluster execution
    slurm {
        process.executor = 'slurm'
        process.queue = { params.slurm_partition ?: 'day' }
        process.memory = { params.slurm_mem ?: '16 GB' }
        process.cpus = { params.slurm_cpus_per_task ?: 4 }
        process.time = { params.slurm_time ?: '24:00:00' }
        process.clusterOptions = { "--account=${params.account ?: 'borzekowski'} --nodes=1" }
    }

    // Apptainer container execution
    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
        apptainer.runOptions = '--bind /vast'
        process.container = params.container_image
    }
}

// Process defaults
process {
    // Default error strategy: retry failed jobs
    errorStrategy = 'retry'
    maxRetries = 2
}

// Execution reports
report {
    enabled = true
    overwrite = true
    file = "logs/nextflow/report.html"
}

timeline {
    enabled = true
    overwrite = true
    file = "logs/nextflow/timeline.html"
}
