# Dockerfile for Fairway Project
# Generated by fairway init
#
# Build with: docker build -t fairway .
# Or with specific git ref: docker build --build-arg FAIRWAY_GIT_REF=fix-apptainer -t fairway .

# If bumping this base image, update constants.CONTAINER_PYTHON_VERSION
# (the dev-mode bind path in cli.py reads that constant).
FROM python:3.10-slim-bookworm

WORKDIR /app

# Build argument for git ref (branch, tag, or commit)
ARG FAIRWAY_GIT_REF=main

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    openjdk-17-jre-headless \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Install Spark
ENV SPARK_VERSION=4.1.1
ENV HADOOP_VERSION=3
RUN curl -sL "https://archive.apache.org/dist/spark/spark-${SPARK_VERSION}/spark-${SPARK_VERSION}-bin-hadoop${HADOOP_VERSION}.tgz" | tar -xz -C /opt \
    && ln -s /opt/spark-${SPARK_VERSION}-bin-hadoop${HADOOP_VERSION} /opt/spark

# Environment variables
ENV SPARK_HOME=/opt/spark
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
ENV LC_ALL=C
ENV VIRTUAL_ENV=/opt/venv

# Create virtual environment (matches Apptainer.def approach)
RUN python3 -m venv /opt/venv

# Upgrade pip and install fairway from GitHub
RUN /opt/venv/bin/pip install --upgrade pip setuptools wheel \
    && echo "Installing fairway[all] from ref: ${FAIRWAY_GIT_REF}..." \
    && /opt/venv/bin/pip install --no-cache-dir "fairway[all] @ git+https://github.com/DISSC-yale/fairway.git@${FAIRWAY_GIT_REF}"

# Set PATH to use venv binaries and Spark
ENV PATH="/opt/venv/bin:$PATH:/opt/spark/bin"

# Tell Spark which Python to use
ENV PYSPARK_PYTHON=/opt/venv/bin/python
ENV PYSPARK_DRIVER_PYTHON=/opt/venv/bin/python

# Default command
CMD ["fairway", "--help"]
