Bootstrap: docker
From: python:3.11-slim

%post
    apt-get update && apt-get install -y --no-install-recommends default-jdk
    rm -rf /var/lib/apt/lists/*
    pip install --no-cache-dir \
        "pyspark==3.5.0" \
        duckdb \
        pytest \
        pytest-cov \
        pandas \
        pyarrow \
        tabulate \
        pyyaml \
        click \
        numpy

%environment
    export JAVA_HOME=/usr/lib/jvm/default-java
    export FAIRWAY_SRC=/workspace/fairway

%runscript
    # Install fairway from bound source directory at launch time
    # Usage: apptainer run --bind $(pwd):/workspace/fairway fairway-dev.sif pytest tests/ -m "not hpc"
    pip install -e ${FAIRWAY_SRC}[dev] --quiet --no-deps
    exec "$@"

%labels
    Description "Fairway dev/test image — fairway installed at launch from bind mount"
    Usage "apptainer run --bind $(pwd):/workspace/fairway fairway-dev.sif pytest tests/"
    Note "Use 'apptainer run', not 'apptainer exec' — exec bypasses %runscript"
